  "keyFeatures": [
    "Minecraft Bedrock Edition protocol implementation",
    "Client and server connection handling with Dial/Listen API",
    "Xbox Live and Microsoft authentication",
    "NBT (Named Binary Tag) encoding and decoding",
    "Complete packet protocol support (229+ packet types)",
    "Resource pack compilation and management",
    "Server query protocol (UT3)",
    "MITM proxy capabilities",
    "Text formatting and color codes"
  ],
  "publicApiSurface": [
    "minecraft.Dial() - Connect to Minecraft server",
    "minecraft.Listen() - Create Minecraft listener/server",
    "minecraft.Dialer - Configure client connections",
    "minecraft.ListenConfig - Configure server listener",
    "minecraft.Conn - Minecraft network connection",
    "auth.RequestLiveToken() - Microsoft authentication",
    "auth.RefreshTokenSource() - Token refresh handling",
    "nbt.Marshal() - Encode NBT data",
    "nbt.Unmarshal() - Decode NBT data",
    "nbt.NewEncoder() - Create NBT encoder",
    "nbt.NewDecoder() - Create NBT decoder",
    "protocol packet types - 229+ Minecraft packets",
    "resource.Compile() - Compile resource packs",
    "resource.Pack - Resource pack structure",
    "text formatting constants - Minecraft colors/formatting",
    "query.Do() - Query server information"
  ]
}
